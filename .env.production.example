# =============================================================================
# SIGAPS — variáveis para deploy gratuito (Render + Supabase + Cloudflare Pages)
# Copie para o painel de cada serviço. NÃO commite valores reais.
# Guia completo: docs/DEPLOY_GRATUITO.md
# =============================================================================

# --- Supabase (banco PostgreSQL + PostGIS) ---
# Connection string: Settings → Database → URI (modo Session ou Transaction)
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public

# --- Render (backend NestJS) ---
NODE_ENV=production
PORT=3000
JWT_SECRET=gere-uma-chave-aleatoria-com-pelo-menos-32-caracteres
JWT_REFRESH_SECRET=outra-chave-aleatoria-diferente-da-jwt
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL do site no Cloudflare Pages (sem barra no final)
# Se tiver preview + produção, separe por vírgula:
FRONTEND_URL=https://sigaps.pages.dev,https://sigaps-passagemfranca.pages.dev

OSM_RELATION_ID_PASSAGEM_FRANCA=332931
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter

# --- Cloudflare Pages (frontend) — Build environment variables ---
VITE_API_URL=https://sigaps-api.onrender.com
# NUNCA use true em produção:
VITE_DEV_AUTO_LOGIN=false

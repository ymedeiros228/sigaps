# PostgreSQL + PostGIS
POSTGRES_USER=sigaps
POSTGRES_PASSWORD=sigaps_secret
POSTGRES_DB=sigaps
DATABASE_URL=postgresql://sigaps:sigaps_secret@127.0.0.1:5432/sigaps?schema=public

# JWT
JWT_SECRET=altere-esta-chave-em-producao-minimo-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=altere-esta-chave-refresh-em-producao
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Município padrão (Passagem Franca - MA)
DEFAULT_MUNICIPALITY_NAME=Passagem Franca
DEFAULT_MUNICIPALITY_STATE=MA
DEFAULT_MUNICIPALITY_LAT=-6.1828
DEFAULT_MUNICIPALITY_LNG=-43.7869

# OSM / Overpass — relação administrativa de Passagem Franca (MA)
# https://www.openstreetmap.org/relation/332931
OSM_RELATION_ID_PASSAGEM_FRANCA=332931
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter

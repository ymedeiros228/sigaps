generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRADOR
  SECRETARIO_SAUDE
  COORDENADOR_APS
  ENFERMEIRO
  ACS
}

enum EntityStatus {
  ATIVO
  INATIVO
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  role          UserRole
  municipalityId String?  @map("municipality_id")
  municipality  Municipality? @relation(fields: [municipalityId], references: [id])
  refreshToken  String?   @map("refresh_token")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  auditLogs     AuditLog[]
  acsProfile    Acs?

  @@map("users")
}

model Municipality {
  id          String   @id @default(uuid())
  name        String
  state       String   @db.VarChar(2)
  prefecture  String   @map("prefecture")
  secretariat String
  logoUrl     String?  @map("logo_url")
  latitude    Float
  longitude   Float
  osmRelationId Int?   @map("osm_relation_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           User[]
  ubsList         Ubs[]
  neighborhoods   Neighborhood[]
  microareas      Microarea[]
  streets         Street[]
  acsList         Acs[]

  @@unique([name, state])
  @@map("municipalities")
}

model Ubs {
  id             String   @id @default(uuid())
  name           String
  address        String
  phone          String?
  coordinator    String?
  latitude       Float
  longitude      Float
  municipalityId String   @map("municipality_id")
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  microareas Microarea[]

  @@map("ubs")
}

model Neighborhood {
  id             String   @id @default(uuid())
  name           String
  municipalityId String   @map("municipality_id")
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  streets Street[]

  @@unique([name, municipalityId])
  @@map("neighborhoods")
}

model Microarea {
  id             String       @id @default(uuid())
  number         Int
  name           String
  color          String       @db.VarChar(7)
  description    String?
  status         EntityStatus @default(ATIVO)
  ubsId          String?      @map("ubs_id")
  ubs            Ubs?         @relation(fields: [ubsId], references: [id])
  municipalityId String       @map("municipality_id")
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  acsId          String?      @unique @map("acs_id")
  acs            Acs?         @relation(fields: [acsId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  streets Street[]
  paintZones MicroareaPaintZone[]

  @@unique([number, municipalityId])
  @@map("microareas")
}

model MicroareaPaintZone {
  id             String    @id @default(uuid())
  name           String?
  microareaId    String    @map("microarea_id")
  microarea      Microarea @relation(fields: [microareaId], references: [id], onDelete: Cascade)
  municipalityId String    @map("municipality_id")
  centerLat      Float     @map("center_lat")
  centerLng      Float     @map("center_lng")
  radiusMeters   Float     @map("radius_meters")
  geojson        Json
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([microareaId])
  @@index([municipalityId])
  @@map("microarea_paint_zones")
}

model Acs {
  id             String       @id @default(uuid())
  name           String
  cpf            String       @unique
  phone          String?
  photoUrl       String?      @map("photo_url")
  status         EntityStatus @default(ATIVO)
  userId         String?      @unique @map("user_id")
  user           User?        @relation(fields: [userId], references: [id])
  municipalityId String       @map("municipality_id")
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  microarea Microarea?

  @@map("acs")
}

model Street {
  id             String   @id @default(uuid())
  osmId          BigInt?  @unique @map("osm_id")
  name           String
  streetType     String?  @map("street_type")
  neighborhoodId String?  @map("neighborhood_id")
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id])
  microareaId    String?  @map("microarea_id")
  microarea      Microarea? @relation(fields: [microareaId], references: [id])
  municipalityId String   @map("municipality_id")
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  lengthMeters   Float?   @map("length_meters")
  propertyCount  Int      @default(0) @map("property_count")
  familyCount    Int      @default(0) @map("family_count")
  inhabitantCount Int     @default(0) @map("inhabitant_count")
  notes          String?
  geojson        Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([municipalityId])
  @@index([microareaId])
  @@index([name])
  @@map("streets")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}
